{
  "name": "GPU-Monitor-AI",
  "version": "1.0.0",
  "description": "GPU Monitor for AI Workloads — Multi-source GPU telemetry dashboard",
  "author": "riversde",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gpu-monitor.ai",
    "productName": "GPU Monitor for AI Workloads",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GPU Monitor for AI Workloads"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  }
}
